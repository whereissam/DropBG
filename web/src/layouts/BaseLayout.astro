---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "DropBG | Local-first background remover for macOS",
  description = "Remove backgrounds on your Mac with a local-first app built for Apple Silicon. No uploads, no subscriptions, no resolution caps."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0c0b" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/screenshot.png" />
    <meta property="og:url" content="https://dropbg.app" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />
  </body>
</html>
