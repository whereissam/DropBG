---
import BaseLayout from "../layouts/BaseLayout.astro";

const pillars = [
  {
    title: "Local-first by default",
    body: "Images stay on your machine. DropBG is designed for people who do not want client photos or product shots moving through a hosted pipeline."
  },
  {
    title: "Fast on Apple Silicon",
    body: "Built with Tauri, Rust, ONNX Runtime, and CoreML so the heavy lifting runs close to the hardware instead of inside a browser tab."
  },
  {
    title: "Simple setup, then offline",
    body: "Download the model once, point at an image, and export transparent PNGs without subscription gates, watermarks, or resolution caps."
  }
];

const steps = [
  "Install the macOS app and download the BiRefNet Lite model once.",
  "Drop in an image, let the model generate a foreground mask, and preview the result.",
  "Save a clean PNG with transparency for design, ecommerce, and content workflows."
];
---

<BaseLayout>
  <header class="relative overflow-clip px-4 pt-4 pb-10 md:pb-14">
    <div class="pointer-events-none absolute top-28 left-[60%] h-[28rem] w-[28rem] rounded-full bg-[radial-gradient(circle,rgba(219,92,63,0.18),transparent_66%)]"></div>
    <div class="mx-auto w-full max-w-[1180px]">
      <nav class="flex flex-col items-start justify-between gap-4 py-4 md:flex-row md:items-center md:py-6">
        <a class="inline-flex items-center gap-3" href="/">
          <img class="h-11 w-11 rounded-2xl shadow-[0_14px_28px_rgba(24,15,8,0.12)]" src="/logo.png" alt="DropBG logo" width="44" height="44" />
          <div class="block">
            <strong class="block text-base font-semibold">DropBG</strong>
            <span class="block text-sm text-[color:var(--muted)]">Background removal for macOS</span>
          </div>
        </a>
        <div class="flex w-full flex-wrap items-center gap-3 md:w-auto">
          <a class="mr-auto text-sm text-[color:var(--muted)] md:mr-0" href="https://github.com/whereissam/DropBG" target="_blank" rel="noreferrer">GitHub</a>
          <a class="inline-flex min-h-12 items-center justify-center rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.72)] px-5 py-3 text-sm font-semibold text-[color:var(--text)] transition duration-300 hover:-translate-y-0.5 hover:bg-white" href="#how-it-works">How it works</a>
          <a class="inline-flex min-h-12 items-center justify-center rounded-full bg-[linear-gradient(135deg,var(--accent),#e3854f)] px-5 py-3 text-sm font-semibold text-[#fffaf3] shadow-[0_18px_35px_rgba(219,92,63,0.28)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_22px_40px_rgba(219,92,63,0.34)]" href="https://github.com/whereissam/DropBG#getting-started" target="_blank" rel="noreferrer">Get started</a>
        </div>
      </nav>

      <div class="grid items-center gap-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.75)] px-4 py-2 text-[0.82rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">
            <span class="h-2.5 w-2.5 rounded-full bg-[linear-gradient(135deg,var(--accent),var(--accent-3))]"></span>
            No uploads. No subscriptions. No caps.
          </span>
          <h1 class="mt-4 max-w-[11ch] text-[clamp(3.2rem,7vw,6.3rem)] leading-[0.95] font-bold">Remove backgrounds on your Mac, not in somebody else’s cloud.</h1>
          <p class="max-w-[62ch] text-[1.08rem] leading-7 text-[color:var(--muted)]">
            DropBG is a local-first background remover for macOS. It runs on Apple Silicon with CoreML acceleration, keeps images private, and turns product shots, portraits, and thumbnails into transparent PNGs in a few clicks.
          </p>
          <div class="mt-6 flex flex-wrap gap-4">
            <a class="inline-flex min-h-12 items-center justify-center rounded-full bg-[linear-gradient(135deg,var(--accent),#e3854f)] px-5 py-3 text-sm font-semibold text-[#fffaf3] shadow-[0_18px_35px_rgba(219,92,63,0.28)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_22px_40px_rgba(219,92,63,0.34)]" href="https://github.com/whereissam/DropBG#getting-started" target="_blank" rel="noreferrer">Run locally</a>
            <a class="inline-flex min-h-12 items-center justify-center rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.72)] px-5 py-3 text-sm font-semibold text-[color:var(--text)] transition duration-300 hover:-translate-y-0.5 hover:bg-white" href="https://github.com/whereissam/DropBG" target="_blank" rel="noreferrer">View repo</a>
          </div>
          <dl class="mt-8 grid gap-3 md:grid-cols-3">
            <div class="rounded-[1.15rem] border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.76)] px-4 py-4 transition duration-300 hover:-translate-y-1">
              <dt class="mb-1 text-[0.78rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">Model</dt>
              <dd class="m-0 font-semibold">BiRefNet Lite</dd>
            </div>
            <div class="rounded-[1.15rem] border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.76)] px-4 py-4 transition duration-300 hover:-translate-y-1">
              <dt class="mb-1 text-[0.78rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">Inference</dt>
              <dd class="m-0 font-semibold">ONNX + CoreML</dd>
            </div>
            <div class="rounded-[1.15rem] border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.76)] px-4 py-4 transition duration-300 hover:-translate-y-1">
              <dt class="mb-1 text-[0.78rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">App stack</dt>
              <dd class="m-0 font-semibold">Tauri 2 + React + Rust</dd>
            </div>
          </dl>
        </div>

        <div class="rounded-[24px] border border-[rgba(67,41,22,0.1)] bg-[rgba(255,250,242,0.78)] p-4 shadow-[var(--shadow)] backdrop-blur-[18px] [animation:rise_0.9s_ease_both]">
          <div class="flex gap-2 px-1 pt-1 pb-4">
            <span class="h-3 w-3 rounded-full bg-[#d3c2ad]"></span>
            <span class="h-3 w-3 rounded-full bg-[#d3c2ad]"></span>
            <span class="h-3 w-3 rounded-full bg-[#d3c2ad]"></span>
          </div>
          <div class="relative">
            <img class="rounded-[1.3rem] border border-[rgba(67,41,22,0.08)]" src="/screenshot.png" alt="DropBG app screenshot" />
            <div class="mt-4 rounded-[1.1rem] bg-[linear-gradient(135deg,#1d7b72,#2f968b)] p-4 text-[#fffaf3] shadow-[0_18px_40px_rgba(19,16,12,0.18)] lg:absolute lg:top-18 lg:-right-4 lg:mt-0 lg:max-w-56 [animation:drift_5s_ease-in-out_infinite]">
              <strong class="mb-1 block">Private workflow</strong>
              <p class="text-sm leading-6">Process images locally and keep originals off third-party servers.</p>
            </div>
            <div class="mt-4 rounded-[1.1rem] bg-[linear-gradient(135deg,#3b2417,#5a3724)] p-4 text-[#fffaf3] shadow-[0_18px_40px_rgba(19,16,12,0.18)] lg:absolute lg:-bottom-4 lg:-left-4 lg:mt-0 lg:max-w-56 [animation:drift_6s_ease-in-out_infinite]">
              <strong class="mb-1 block">Made for shipping</strong>
              <p class="text-sm leading-6">Desktop UX now, landing page and releases next.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <main>
    <section class="px-4 py-8 md:py-12">
      <div class="mx-auto w-full max-w-[1180px]">
        <div class="mb-6 max-w-[660px]">
          <span class="inline-flex items-center gap-2 rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.75)] px-4 py-2 text-[0.82rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">
            <span class="h-2.5 w-2.5 rounded-full bg-[linear-gradient(135deg,var(--accent),var(--accent-3))]"></span>
            Why DropBG
          </span>
          <h2 class="mt-4 mb-3 text-[clamp(2.2rem,6vw,4rem)] leading-none font-bold">Built for the part of the workflow that cloud tools keep charging for.</h2>
          <p class="text-[1.02rem] text-[color:var(--muted)]">
            The app is positioned around privacy, local speed, and practical output quality. The landing page keeps that message tight instead of sounding like a generic AI tool.
          </p>
        </div>
        <div class="grid gap-4 lg:grid-cols-3">
          {pillars.map((pillar) => (
            <article class="rounded-[24px] border border-[rgba(67,41,22,0.1)] bg-[rgba(255,250,242,0.78)] p-6 shadow-[var(--shadow)] backdrop-blur-[18px] transition duration-300 hover:-translate-y-1.5">
              <h3 class="mb-3 text-2xl font-bold">{pillar.title}</h3>
              <p class="leading-7 text-[color:var(--muted)]">{pillar.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="how-it-works" class="px-4 py-8 md:py-12">
      <div class="mx-auto grid w-full max-w-[1180px] gap-5">
        <div class="mb-2 max-w-[660px]">
          <span class="inline-flex items-center gap-2 rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.75)] px-4 py-2 text-[0.82rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">
            <span class="h-2.5 w-2.5 rounded-full bg-[linear-gradient(135deg,var(--accent),var(--accent-3))]"></span>
            How it works
          </span>
          <h2 class="mt-4 mb-3 text-[clamp(2.2rem,6vw,4rem)] leading-none font-bold">A straightforward pipeline, exposed as a lightweight Mac app.</h2>
          <p class="text-[1.02rem] text-[color:var(--muted)]">
            The current product scope in the repo is clear: single-image removal first, then batch workflows, then background replacement and release polish.
          </p>
        </div>
        <div class="grid gap-4 lg:grid-cols-3">
          {steps.map((step, index) => (
            <article class="rounded-[24px] border border-[rgba(67,41,22,0.1)] bg-[rgba(255,250,242,0.78)] p-6 shadow-[var(--shadow)] backdrop-blur-[18px] transition duration-300 hover:-translate-y-1.5">
              <span class="mb-4 inline-flex text-sm font-extrabold tracking-[0.08em] text-[color:var(--accent)]">{String(index + 1).padStart(2, "0")}</span>
              <p class="leading-7 text-[color:var(--muted)]">{step}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-4 py-8 md:py-12">
      <div class="mx-auto grid w-full max-w-[1180px] gap-6 rounded-[24px] border border-[rgba(67,41,22,0.1)] bg-[rgba(255,250,242,0.78)] p-8 shadow-[var(--shadow)] backdrop-blur-[18px]">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.75)] px-4 py-2 text-[0.82rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">
            <span class="h-2.5 w-2.5 rounded-full bg-[linear-gradient(135deg,var(--accent),var(--accent-3))]"></span>
            Shipping path
          </span>
          <h2 class="mt-4 text-[clamp(2rem,5vw,3.8rem)] leading-none font-bold">Current focus: finish the app, publish releases, then scale the workflow.</h2>
        </div>
        <div class="grid gap-4 lg:grid-cols-3">
          <div class="rounded-[1.2rem] border border-[rgba(67,41,22,0.08)] bg-[rgba(255,251,246,0.8)] p-5 transition duration-300 hover:-translate-y-1">
            <strong class="mb-1 block">Now</strong>
            <p class="text-[color:var(--muted)]">Landing page, GitHub-facing onboarding, and the single-image local workflow.</p>
          </div>
          <div class="rounded-[1.2rem] border border-[rgba(67,41,22,0.08)] bg-[rgba(255,251,246,0.8)] p-5 transition duration-300 hover:-translate-y-1">
            <strong class="mb-1 block">Next</strong>
            <p class="text-[color:var(--muted)]">Batch processing, smarter output naming, and save-location options.</p>
          </div>
          <div class="rounded-[1.2rem] border border-[rgba(67,41,22,0.08)] bg-[rgba(255,251,246,0.8)] p-5 transition duration-300 hover:-translate-y-1">
            <strong class="mb-1 block">Later</strong>
            <p class="text-[color:var(--muted)]">Background replacement, polished installers, and broader platform coverage.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="px-4 py-8 pb-16 md:py-12 md:pb-20">
      <div class="mx-auto flex w-full max-w-[1180px] flex-col items-start justify-between gap-6 lg:flex-row lg:items-end">
        <div class="max-w-[760px]">
          <span class="inline-flex items-center gap-2 rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.75)] px-4 py-2 text-[0.82rem] uppercase tracking-[0.08em] text-[color:var(--muted)]">
            <span class="h-2.5 w-2.5 rounded-full bg-[linear-gradient(135deg,var(--accent),var(--accent-3))]"></span>
            Use the repo today
          </span>
          <h2 class="mt-4 text-[clamp(2rem,5vw,3.8rem)] leading-none font-bold">DropBG already has a clear technical direction. The landing page should make that obvious in under ten seconds.</h2>
        </div>
        <div class="flex flex-wrap gap-3">
          <a class="inline-flex min-h-12 items-center justify-center rounded-full bg-[linear-gradient(135deg,var(--accent),#e3854f)] px-5 py-3 text-sm font-semibold text-[#fffaf3] shadow-[0_18px_35px_rgba(219,92,63,0.28)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_22px_40px_rgba(219,92,63,0.34)]" href="https://github.com/whereissam/DropBG#getting-started" target="_blank" rel="noreferrer">Install prerequisites</a>
          <a class="inline-flex min-h-12 items-center justify-center rounded-full border border-[rgba(67,41,22,0.08)] bg-[rgba(255,248,239,0.72)] px-5 py-3 text-sm font-semibold text-[color:var(--text)] transition duration-300 hover:-translate-y-0.5 hover:bg-white" href="https://github.com/whereissam/DropBG/blob/main/docs/TODO.md" target="_blank" rel="noreferrer">See roadmap</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
